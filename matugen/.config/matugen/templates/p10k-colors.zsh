# Home directory - WYRÓŻNIONY kolor
typeset -g POWERLEVEL9K_HOME_FOREGROUND='#{{colors.on_tertiary_container.default.hex_stripped}}'
typeset -g POWERLEVEL9K_HOME_SUBFOLDER_FOREGROUND='#{{colors.tertiary.default.hex_stripped}}'

# Special directories
typeset -g POWERLEVEL9K_ETC_FOREGROUND='#{{colors.on_secondary_container.default.hex_stripped}}'

# Git status colors - WYRAZISTE różnice
typeset -g POWERLEVEL9K_VCS_CLEAN_FOREGROUND='#{{colors.on_primary_container.default.hex_stripped}}'
